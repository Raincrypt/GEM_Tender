# ============================================================
#  GEM Tender Procurement Ecosystem — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit the actual .env file to version control.
# ============================================================

# ── JWT Authentication ──────────────────────────────────────
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_RANDOM_256BIT_KEY

# Set to true ONLY in local dev to allow auto-admin login without a token.
# Must be false in staging/production.
AUTH_BYPASS_ENABLED=false

# ── API Docs ────────────────────────────────────────────────
# Set to false to disable /docs and /redoc in production.
ENABLE_DOCS=true

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:8000,http://127.0.0.1:8000

# ── MongoDB ─────────────────────────────────────────────────
MONGO_USER=gemadmin
MONGO_PASS=CHANGE_ME_MONGO_PASSWORD
MONGO_URL=mongodb://gemadmin:CHANGE_ME_MONGO_PASSWORD@localhost:27017/gem_tender?authSource=admin

# ── Redis ───────────────────────────────────────────────────
REDIS_PASS=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0

# ── MFA / TOTP (optional) ──────────────────────────────────
# Only needed if MFA is enabled for any user.
# MFA_TOTP_SECRET=BASE32_SECRET_HERE

# ── AI / LLM Provider Configuration ─────────────────────────
# The system supports 3 providers in a fallback chain.
# Set LLM_PROVIDER to the preferred default: ollama | gemini | openai
LLM_PROVIDER=ollama

# ── Ollama (Open-Source, recommended — fully local & private) ─
# Install Ollama from https://ollama.com/ and pull a model first:
#   ollama pull llama3
# Then set the URL and model name:
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# ── Gemini API (optional, cloud-based) ───────────────────────
# Get a key from https://aistudio.google.com/
# Only used if STRICT_OPEN_SOURCE=false and LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_google_gemini_api_key_here

# ── OpenAI API (optional, cloud-based) ───────────────────────
# Get a key from https://platform.openai.com/
# Only used if STRICT_OPEN_SOURCE=false and LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

# ── Open Source Compliance Mode ──────────────────────────────
# Set to true (recommended) to enforce strict local, offline execution.
# This disables and blocks fallbacks to proprietary cloud APIs (Gemini/OpenAI)
# to guarantee local data residency and full regulatory compliance (GPC/DSP).
STRICT_OPEN_SOURCE=true

