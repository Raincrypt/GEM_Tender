# ============================================================
#  GEM Tender Intelligence System — Production Environment
#  COPY THIS FILE TO .env AND FILL IN REAL VALUES
#  NEVER COMMIT .env TO GIT
# ============================================================

# ── Security (CHANGE BEFORE PRODUCTION) ─────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_256BIT_SECRET_KEY_HERE

# Disable in production (true only for local dev testing)
AUTH_BYPASS_ENABLED=false

# ── Database Credentials ────────────────────────────────────
MONGO_USER=gemadmin
MONGO_PASS=CHANGE_ME_STRONG_MONGO_PASSWORD

REDIS_PASS=CHANGE_ME_STRONG_REDIS_PASSWORD

# Options: llama3.1:8b (recommended) | gemma2:2b (lightweight) | mistral:7b-instruct
OLLAMA_MODEL=llama3.1:8b

# ── CORS — Set to your actual domain in production ──────────
# Example: https://gem.yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ── API Keys (optional — only if using cloud LLMs) ──────────
# Leave empty to use Ollama (local, free, private)
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Server Settings ─────────────────────────────────────────
# Set to false in production to hide /docs endpoint
ENABLE_DOCS=true
